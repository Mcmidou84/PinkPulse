    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-xss-sanitizer": "^2.0.1",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
